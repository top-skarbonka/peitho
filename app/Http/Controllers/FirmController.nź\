<?php

namespace App\Http\Controllers;

use App\Models\Firm;
use App\Models\LoyaltyCard;
use App\Models\LoyaltyStamp;
use App\Models\RegistrationToken;
use App\Models\Transaction;
use App\Services\AuditLogger;
use App\Services\Sms\SmsApiSender;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Str;

class FirmController extends Controller
{
    private function firm(): Firm
    {
        $firm = Auth::guard('company')->user();

        if (!$firm) {
            abort(403, 'Brak zalogowanej firmy');
        }

        return $firm;
    }

    public function dashboard()
    {
        $firm = $this->firm();

        $totalClients = LoyaltyCard::where('firm_id', $firm->id)
            ->distinct('client_id')
            ->count('client_id');

        $totalTransactions = DB::table('client_point_logs')
            ->where('firm_id', $firm->id)
            ->where('points', '>', 0)
            ->count();

        $totalPoints = DB::table('client_points')
            ->where('firm_id', $firm->id)
            ->sum('points');

        $avgPoints = $totalTransactions > 0
            ? $totalPoints / $totalTransactions
            : 0;

        /*
        |--------------------------------------------------------------------------
        | 🔥 NOWE — WYKRESY (REALNE DANE)
        |--------------------------------------------------------------------------
        */

        // 📈 Klienci per dzień (ostatnie 14 dni)
        $clientsPerDay = DB::table('loyalty_cards')
            ->where('firm_id', $firm->id)
            ->selectRaw("DATE(created_at) as date, COUNT(DISTINCT client_id) as count")
            ->groupBy('date')
            ->orderBy('date')
            ->get();

        // 📊 Punkty per dzień (ostatnie 14 dni)
        $pointsPerDay = DB::table('client_point_logs')
            ->where('firm_id', $firm->id)
            ->where('points', '>', 0)
            ->selectRaw("DATE(created_at) as date, SUM(points) as total")
            ->groupBy('date')
            ->orderBy('date')
            ->get();

        return view('firm.dashboard', compact(
            'totalClients',
            'totalTransactions',
            'totalPoints',
            'avgPoints',
            'clientsPerDay',
            'pointsPerDay'
        ));
    }

    public function showPointsForm()
    {
        $firm = $this->firm();

        $settings = DB::table('program_settings')
            ->where('firm_id', $firm->id)
            ->first();

        return view('firm.points.index', compact('settings'));
    }

    public function showAddClientPointsForm()
    {
        return view('firm.points.add-client');
    }

